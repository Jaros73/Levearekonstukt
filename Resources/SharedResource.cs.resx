  <data name="Service4Title" xml:space="preserve">
    <value>Fasády a venkovní úpravy</value>
  </data>
  <data name="Service4Text" xml:space="preserve">
    <value>Opravy fasád, renovace povrchů a další práce, které zlepší vzhled objektu i jeho ochranu před počasím.</value>
  </data>
  <data name="Service5Title" xml:space="preserve">
