@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

@{
    var kultura = ViewContext.RouteData.Values["kultura"]?.ToString()?.ToLowerInvariant() ?? "cs";
    var supportedCultures = new[] { "cs", "en", "de", "uk" };

    var scheme = Context.Request.Scheme;
    var host = Context.Request.Host.Value;
    var baseUrl = $"{scheme}://{host}";
    var path = Context.Request.Path.Value ?? string.Empty;

    string ReplaceCultureInPath(string currentPath, string newCulture)
    {
        if (string.IsNullOrWhiteSpace(currentPath) || currentPath == "/")
        {
            return $"/{newCulture}";
        }

        var segments = currentPath
            .Split('/', StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        if (segments.Count > 0 && supportedCultures.Contains(segments[0]))
        {
            segments[0] = newCulture;
        }
        else
        {
            segments.Insert(0, newCulture);
        }

        return "/" + string.Join('/', segments);
    }

    string BuildAbsoluteUrl(string relativePath)
    {
        return $"{baseUrl}{relativePath}";
    }

    string BuildSectionUrl(string culture, string sectionId)
    {
        return $"/{culture}#{sectionId}";
    }

    var csPath = ReplaceCultureInPath(path, "cs");
    var enPath = ReplaceCultureInPath(path, "en");
    var dePath = ReplaceCultureInPath(path, "de");
    var ukPath = ReplaceCultureInPath(path, "uk");

    var csUrl = BuildAbsoluteUrl(csPath);
    var enUrl = BuildAbsoluteUrl(enPath);
    var deUrl = BuildAbsoluteUrl(dePath);
    var ukUrl = BuildAbsoluteUrl(ukPath);

    var canonicalUrl = kultura switch
    {
        "en" => enUrl,
        "de" => deUrl,
        "uk" => ukUrl,
        _ => csUrl
    };

    var title = Localizer["PageTitle"];
    var description = Localizer["MetaDescription"];

    // Uprav cestu podle skutečného souboru obrázku
    var ogImageUrl = BuildAbsoluteUrl("/images/og-image.jpg");
}
<!DOCTYPE html>
<html lang="@kultura">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@title - LEVEA KONSTRUKCE</title>
    <meta name="description" content="@description" />
    <meta name="robots" content="index,follow" />

    <link rel="canonical" href="@canonicalUrl" />
    <link rel="alternate" hreflang="cs" href="@csUrl" />
    <link rel="alternate" hreflang="en" href="@enUrl" />
    <link rel="alternate" hreflang="de" href="@deUrl" />
    <link rel="alternate" hreflang="uk" href="@ukUrl" />
    <link rel="alternate" hreflang="x-default" href="@csUrl" />

    <meta property="og:title" content="@title - LEVEA KONSTRUKCE" />
    <meta property="og:description" content="@description" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:site_name" content="LEVEA KONSTRUKCE" />
    <meta property="og:image" content="@ogImageUrl" />
    <meta property="og:locale" content="@kultura" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@title - LEVEA KONSTRUKCE" />
    <meta name="twitter:description" content="@description" />
    <meta name="twitter:image" content="@ogImageUrl" />

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="brand" href="/@kultura">
                <span class="brand-title">LEVEA</span>
                <span class="brand-subtitle">KONSTRUKCE</span>
            </a>

            <nav class="main-nav" aria-label="@Localizer["NavAriaLabel"]">
                <a href="@BuildSectionUrl(kultura, "o-nas")">@Localizer["NavAbout"]</a>
                <a href="@BuildSectionUrl(kultura, "sluzby")">@Localizer["NavServices"]</a>
                <a href="@BuildSectionUrl(kultura, "realizace")">@Localizer["NavProjects"]</a>
                <a href="@BuildSectionUrl(kultura, "spoluprace")">@Localizer["NavProcess"]</a>
                <a href="@BuildSectionUrl(kultura, "kontakt")">@Localizer["NavContact"]</a>
            </nav>

            <div class="header-right">
                <a class="phone-link" href="tel:+420721077958">+420 721 077 958</a>

                <div class="language-switcher" aria-label="@Localizer["LanguageSwitcherAriaLabel"]">
                    @if (kultura != "cs")
                    {
                        <a href="@csPath">CS</a>
                    }
                    @if (kultura != "en")
                    {
                        <a href="@enPath">EN</a>
                    }
                    @if (kultura != "de")
                    {
                        <a href="@dePath">DE</a>
                    }
                    @if (kultura != "uk")
                    {
                        <a href="@ukPath">UK</a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-inner">
            <div class="footer-block">
                <strong>LEVEA KONSTRUKCE</strong>
                <span>IČO: 24628204</span>
            </div>

            <div class="footer-block">
                <a href="tel:+420721077958">+420 721 077 958</a>
                <a href="mailto:lvarekonstrukt@seznam.cz">lvarekonstrukt@seznam.cz</a>
            </div>

            <div class="footer-block footer-languages">
                <a href="@csPath">CS</a>
                <a href="@enPath">EN</a>
                <a href="@dePath">DE</a>
                <a href="@ukPath">UK</a>
            </div>
        </div>
    </footer>
    <a href="https://www.toplist.cz"
           id="toplistcz1841576"
           title="TOPlist"
           style="display:none;">

        <noscript>
            <img src="https://toplist.cz/count.asp?id=1841576&njs=1"
                 border="0"
                 alt="TOPlist"
                 width="1"
                 height="1" />
        </noscript>

        <script>
                    (function(d,e,s) {
                        d.getElementById('toplistcz1841576').innerHTML =
                        '<img src="https://toplist.cz/count.asp?id=1841576&http=' +
                        e(d.referrer) + '&t=' + e(d.title) +
                        '&l=' + e(d.URL) + '&wi=' + e(s.width) +
                        '&he=' + e(s.height) + '&cd=' +
                        e(s.colorDepth) +
                        '" width="1" height="1" border="0" alt="TOPlist" />';
                    }(document,encodeURIComponent,window.screen))
        </script>

    </a>
</body>
</html>